---
interface Props {
	title: string;
	body: string;
	description: string;
}

const { title, body, description } = Astro.props;
---

<div class="bg-trancperent">
    <div
      class="container mx-auto space-y-16 px-4 py-16 lg:px-8 lg:py-32 xl:max-w-7xl"
    >
      <div class="text-center">
        <div
          class="mb-1 text-sm font-bold uppercase tracking-wider text-teal-600 dark:text-teal-500"
        >
          {description}
        </div>
        <h2 class="scroll-m-20 text-4xl font-extrabold tracking-tight lg:text-5xl">
          {title}
        </h2>
        <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight">
          {body}
        </h3>
      </div>
    </div>
  </div>